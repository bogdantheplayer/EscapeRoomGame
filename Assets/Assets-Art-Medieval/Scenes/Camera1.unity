MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1853561604}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: a592eed1dd8d70541bab08fb72741cbc, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  infoTitle: Guernica
  infoText: 'Una dintre cele mai cunoscute picturi ale spaniolului Pablo Picasso
    este Guernica.

    In pictura se ilustreaza tragediile si urmarile Razboiului
    Civil din Spania, de la o femeie indurerata cu bratele intinse, un barbat mutilat,
    pana la un cal injunghiat. Dorinta lui Picasso a fost sa evidenteze in fata intregii
    lumi brutalitatea cu care aviatia germana a bombardat orasul Guernica.

    Pictura
    poate fi admirata in Muzeul Reina Sofia din Madrid.'
