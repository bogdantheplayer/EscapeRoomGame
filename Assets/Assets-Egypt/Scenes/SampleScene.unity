--- !u!114 &1095989260
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1095989259}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: ea81026d31b2948fc8f4cfc33bf9220f, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  listaIntrebari:
  - textulIntrebarii: "Care era spa\u021Biul preferat al principesei Maria din castelul
      Peli\u0219or?"
    raspunsA: Camera de aur
    raspunsB: "Buc\u0103t\u0103ria"
    raspunsC: "Camera secret\u0103 din subsol"
    raspunsD: "Gr\u0103dina"
    indexRaspunsCorect: 0
  - textulIntrebarii: "\xCEn ce stil artistic \u0219i arhitectural este decorat\u0103
      Camera de Aur, reflect\xE2nd viziunea romantic\u0103 \u0219i misterioas\u0103
      a Reginei Maria?"
    raspunsA: "Baroc T\xE2rziu"
    raspunsB: Neogotic
    raspunsC: Art Nouveau
    raspunsD: Clasicism francez
    indexRaspunsCorect: 2
  - textulIntrebarii: "Ce eveniment, cu o puternic\u0103 \xEEnc\u0103rc\u0103tur\u0103
      istoric\u0103 a avut loc \xEEn Camera de Aur pe 18 iulie 1938?"
    raspunsA: "Regele Mihai a fost oblicat s\u0103 abdice"
    raspunsB: Decesul reginei Maria
    raspunsC: "A fost ascuns Tezaurul Rom\xE2niei "
    raspunsD: "Ferdinand a semnat intrarea \u021B\u0103rii \xEEn r\u0103zboi"
    indexRaspunsCorect: 1
  - textulIntrebarii: "Ce relicv\u0103 pre\u021Bioas\u0103 apar\u021Bin\xE2nd Reginei
      Maria a fost a\u0219ezat\u0103 pe un piedestal, chiar \xEEn mijlocul Camerei
      de Aur, \xEEn anul 2015?"
    raspunsA: "Coroana purtat\u0103 la \xEEncoronarea de la Alba Iulia"
    raspunsB: "Jurnalul ei secret din timpul r\u0103zboiului"
    raspunsC: "Colierul cu safire primit de la \u021Aarul Rusiei"
    raspunsD: Inima Reginei
    indexRaspunsCorect: 3
  - textulIntrebarii: "C\xE2nd are loc inaugurarea oficial\u0103 a Castelului Pele\u0219?"
    raspunsA: 1883
    raspunsB: 1893
    raspunsC: 1912
    raspunsD: 1920
    indexRaspunsCorect: 0
  textIntrebareUI: {fileID: 1936725197}
  textButonA: {fileID: 1670995745}
  textButonB: {fileID: 895190896}
  textButonC: {fileID: 221058917}
  textButonD: {fileID: 276234511}
  panouIntrebari: {fileID: 1548589939}
  scriptulUsii: {fileID: 805444334}
